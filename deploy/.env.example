DEPLOY_SSH_HOST=loose.bz
DEPLOY_SSH_PORT=22224
DEPLOY_SSH_USER=codex
DEPLOY_SSH_KEY=/home/your-linux-user/.ssh/id_ed25519
DEPLOY_WSL_DISTRO=Ubuntu

# Optional overrides
DEPLOY_REMOTE_ROOT=/home/codex/1g1a/web
DEPLOY_REMOTE_TMP_DIR=/tmp
DEPLOY_IMAGE=1g1a-app:latest
DEPLOY_CONTAINER=1g1a-app
DEPLOY_APP_URL=https://1g1a.loose.bz
DEPLOY_LOCAL_HEALTHCHECK_URL=http://127.0.0.1:8080/
DEPLOY_PUBLIC_HEALTHCHECK_URL=https://1g1a.loose.bz/
DEPLOY_DB_ENV_FILE=/home/codex/1g1a/web/config/db.env
DEPLOY_NGINX_CONF_SOURCE=/home/codex/1g1a/web/deploy/1g1a.nginx.conf
DEPLOY_NGINX_CONF_TARGET=/etc/nginx/conf.d/1g1a.conf
